{
    "version": "1.37",
    "description": "A free, simple and lightweight app for monitoring memory timings on Ryzen platform.",
    "homepage": "https://zentimings.com/",
    "license": "GPL-3.0-only",
    "url": "https://github.com/irusanov/ZenTimings/releases/download/v1.37/ZenTimings_v1.37.zip",
    "hash": "fbea77692d7e775d7ea78a6157705f4b3446c44280b05a8bea5adc1f32b076a0",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\settings.xml\")) {",
        "    New-Item \"$dir\\settings.xml\" -ItemType File -Value '<?xml version=\"1.0\" encoding=\"utf-8\"?><AppSettings><CheckForUpdates>false</CheckForUpdates></AppSettings>' | Out-Null",
        "}"
    ],
    "shortcuts": [
        [
            "ZenTimings.exe",
            "ZenTimings"
        ]
    ],
    "persist": "settings.xml",
    "checkver": {
        "script": [
            "try {",
            "    $latest = Invoke-RestMethod https://api.github.com/repositories/235689342/releases/latest",
            "    $latest.tag_name, $latest.assets[0].name -join ' '",
            "}",
            "catch { '' }"
        ],
        "regex": "\\Av(?<tag>[\\S]+) ZenTimings_v([a-z\\d.-]+)\\.zip\\Z"
    },
    "autoupdate": {
        "url": "https://github.com/irusanov/ZenTimings/releases/download/v$matchTag/ZenTimings_v$version.zip",
        "hash": {
            "url": "https://zentimings.com/",
            "regex": "MD5: $md5"
        }
    }
}
